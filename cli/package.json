{
  "name": "skill manage-cli",
  "version": "0.1.0",
  "description": "Visual CLI for AI Skills Bank aggregation and sync workflows",
  "type": "module",
  "author": "ASUS",
  "homepage": "https://github.com/<your-username>/skill manage-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/<your-username>/skill manage-cli.git"
  },
  "bugs": {
    "url": "https://github.com/<your-username>/skill manage-cli/issues"
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "skills-bank": "./src/index.mjs"
  },
  "scripts": {
    "start": "node ./src/index.mjs --help",
    "doctor": "node ./src/index.mjs doctor --project ..\\..",
    "security": "node ./src/index.mjs security --project ..\\..",
    "release:check": "npm run doctor && npm run security && node ./src/index.mjs --help",
    "pack:preview": "npm pack --dry-run",
    "prepublishOnly": "npm run doctor"
  },
  "keywords": [
    "ai",
    "skills",
    "cli",
    "copilot",
    "gemini",
    "antigravity"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.3",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1"
  }
}
