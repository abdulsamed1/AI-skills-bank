# Core Provider Settings
LLM_PROVIDER="groq"
LLM_API_KEY=""

# Model Selection (defaults to llama-3.3-70b-versatile if not set)
LLM_MODEL="openai/gpt-oss-20b"

# Pipeline Control
LLM_ENABLED="true"

# Performance Tuning (Groq is very fast, so we can use larger batches)
LLM_BATCH_SIZE=10
LLM_MAX_RETRIES=3

