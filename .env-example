# Core Provider Settings

# Pipeline Control
LLM_ENABLED="true"

# Performance Tuning
LLM_BATCH_SIZE=20
LLM_CONCURRENCY=10
LLM_MAX_RETRIES=2
LLM_INITIAL_BACKOFF_MS=200
LLM_MAX_BACKOFF_MS=2000
LLM_TIMEOUT_SECS=30

# Primary LLM Provider (openai-compatible API)
LLM_PROVIDER=openai
LLM_API_URL=https://api.sambanova.ai/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=Meta-Llama-3.3-70B-Instruct

# Fallback provider (auto-used when primary returns permanent errors like 410 Gone)
LLM_FALLBACK_PROVIDER=groq
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

GITHUB_TOKEN=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
HYPERBOLIC_API_TOKEN=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
COMETAPI_KEY=
MEMOS_API_KEY=
MEMOS_PROXY_PORT=
OLLAMA_HOST=
